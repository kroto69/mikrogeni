# Server Configuration
PORT=1997
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# Optional bootstrap admin (for first setup only)
# Leave empty to disable automatic admin seeding.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# GenieACS Configuration
GENIEACS_URL=http://localhost:7557/devices
ACS_AUTO_REFRESH_ENABLED=false
ACS_AUTO_REFRESH_INTERVAL=1h
ACS_AUTO_REFRESH_BATCH_SIZE=50

# Telegram Bot (optional)
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
